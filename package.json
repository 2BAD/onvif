  "type": "module",
  "exports": "./build/index.mjs",
  "typings": "./build/index.d.mts",
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsdown",
    "check": "run-p check:*",
    "check:eslint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "check:biome": "biome check ./source",
    "fix": "run-s fix:code fix:format",
    "fix:code": "run-s 'check:eslint -- --fix'",
    "fix:format": "biome format --write ./source",
    "prepublishOnly": "run-s build",
    "preversion": "run-s check test build",
    "test": "vitest run",
    "test:integration": "vitest run integration --coverage",
    "test:unit": "vitest run unit --coverage"
  },
  "devDependencies": {
    "@2bad/axiom": "1.0.3",
    "@2bad/tsconfig": "3.0.2",
    "@biomejs/biome": "1.9.4",
    "@types/node": "22.19.17",
    "@vitest/coverage-v8": "3.2.4",
    "fast-xml-parser": "5.6.0",
    "npm-run-all2": "7.0.2",
    "tsdown": "0.21.9",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.2.4"
  },
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=22"
  },
  "volta": {
    "node": "24.14.1",
    "npm": "11.12.1"
  }
}
